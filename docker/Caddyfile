# Caddyfile for hi-agent docs (static export + WebContainers)
#
# Listens on :80 inside the container; terminate HTTPS at the
# upstream proxy / load balancer (or replace ":80" with your
# domain to let Caddy obtain certificates automatically).

{
	# Disable the admin API; we don't need it inside the container.
	admin off
	# Quieter logs by default; tune as needed.
	persist_config off
}

:80 {
	root * /srv
	encode zstd gzip

	# --- WebContainers requirements ---------------------------------
	# COOP/COEP are mandatory for `crossOriginIsolated`, which in turn
	# is required for SharedArrayBuffer / WebContainer boot.
	@webcontainerPages path /courses/hi-agent/labs/* /courses/hi-agent/chat/01-getting-started /courses/hi-agent/chat/01-getting-started/*
	header @webcontainerPages {
		Cross-Origin-Embedder-Policy "require-corp"
		Cross-Origin-Opener-Policy   "same-origin"
		Cross-Origin-Resource-Policy "cross-origin"
	}

	header {
		# Hardening
		X-Content-Type-Options "nosniff"
		Referrer-Policy        "strict-origin-when-cross-origin"

		# Default Cache-Control for HTML pages (5 min). The leading `?`
		# means "only set if the response does not already have this
		# header"; immutable assets below override per-route.
		?Cache-Control "public, max-age=300"
	}

	@hashedAssets path /_next/static/* /_pagefind/*
	header @hashedAssets Cache-Control "public, max-age=31536000, immutable"

	# WebContainer snapshots are content-addressed (`*-vN.bin` / file
	# names embedded in the manifest); cache them aggressively so a
	# second visit to a course page hydrates the runtime instantly.
	@webcontainerSnapshots path /webcontainer-snapshots/*
	header @webcontainerSnapshots Cache-Control "public, max-age=31536000, immutable"

	# PWA assets ------------------------------------------------------
	# /sw.js MUST never be cached by intermediate proxies; otherwise a
	# stale Service Worker can lock users out of new releases.
	@serviceWorker path /sw.js
	header @serviceWorker {
		Cache-Control      "no-store, max-age=0"
		Service-Worker-Allowed "/"
	}

	# Web app manifest – tiny, infrequent, but content-type matters.
	@webManifest path /manifest.webmanifest
	header @webManifest {
		Content-Type "application/manifest+json; charset=utf-8"
		Cache-Control "public, max-age=86400"
	}

	# PWA icons are content-addressed by name; safe to cache forever.
	@pwaIcons path /icons/*
	header @pwaIcons Cache-Control "public, max-age=31536000, immutable"

	# Pagefind ships small WASM/JSON shards; make sure they're served
	# with sensible MIME types.
	@wasm path *.wasm
	header @wasm Content-Type "application/wasm"

	# --- API reverse proxy ------------------------------------------
	# /api/* 走 auth-server (Next.js standalone, 监听 :3000)。
	# 必须放在 try_files 之前，否则静态回退会把 /api/foo 当作不存在的
	# 静态资源直接 rewrite 到 /404.html。
	@api path /api/*
	handle @api {
		# 安全约束：
		# - X-Forwarded-For/X-Real-IP 用 = 覆盖（不带 +=），意味着 Caddy 上游伪造的 XFF
		#   会被强制重写为真实 remote_host。这要求 Caddy 必须是面向客户端的最外层网关；
		#   若未来需要在 Caddy 之外再加一层 HTTPS/CDN 反代，应改为 += 追加并由 auth-server
		#   配置 trust proxy hop 数。
		# - X-Forwarded-Proto 透传上游 header（外层未写入时为空），让 auth-server 端
		#   根据 SECURE_COOKIE/TRUST_PROXY 自行决策；与生产部署链一致。
		reverse_proxy auth-server:3000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {http.request.header.X-Forwarded-Proto}
		}
	}

	# --- Static export routing --------------------------------------
	# Next.js export with `trailingSlash: true` emits `out/<route>/index.html`.
	# Resolve in this order:
	#   1. exact file (e.g. /favicon.ico, /_next/static/...)
	#   2. <path>/index.html (canonical doc routes)
	#   3. <path>.html       (top-level pages without trailing slash)
	#   4. fallback to /404.html
	try_files {path} {path}/index.html {path}.html /404.html

	file_server

	handle_errors {
		@notFound expression {http.error.status_code} == 404
		rewrite @notFound /404.html
		file_server
	}
}

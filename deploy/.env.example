# Hi-Agent 部署环境变量样例
# 实际值放在同目录 .env（chmod 600，已 .gitignore），由人工或运维写入。
# CI/CD（CNB pipeline）只会写入 HI_AGENT_IMAGE / AUTH_SERVER_IMAGE。
# 强随机：openssl rand -base64 32

HI_AGENT_IMAGE=
AUTH_SERVER_IMAGE=

POSTGRES_DB=hi_agent
POSTGRES_USER=hi_agent
POSTGRES_PASSWORD=

OTP_PEPPER=
SESSION_TTL_DAYS=30
SECURE_COOKIE=true

SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Hi-Agent <noreply@example.com>"

APP_BASE_URL=https://hi-agent.local

# 是否信任反向代理转发的 X-Forwarded-For / X-Real-IP（PR-4 Caddy 接入后置 true；裸跑保持 false）
TRUST_PROXY=false

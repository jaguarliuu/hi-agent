{
  "name": "hi-agent-docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "studio": "node scripts/run-studio.mjs",
    "studio:restore": "node scripts/restore-studio.mjs",
    "build:snapshots": "node scripts/build-webcontainer-snapshots.mjs",
    "prebuild": "node scripts/strip-studio.mjs",
    "build": "npm run build:snapshots && next build && pagefind --site out --output-subdir _pagefind",
    "postbuild": "node scripts/restore-studio.mjs",
    "start": "next start",
    "export": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --pass-with-no-tests"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@giscus/react": "^3.1.0",
    "@monaco-editor/react": "^4.7.0",
    "@webcontainer/api": "^1.5.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "idb-keyval": "^6.2.1",
    "next": "^15.1.6",
    "nextra": "4.5.1",
    "nextra-theme-docs": "4.5.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@webcontainer/snapshot": "^0.1.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^26.0.0",
    "pagefind": "^1.5.2",
    "typescript": "^5.7.3",
    "vitest": "^3.1.3"
  },
  "overrides": {
    "dompurify": "^3.4.2",
    "postcss": "^8.5.14"
  }
}
